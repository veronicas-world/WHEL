# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# Reddit pipeline outputs (generated, not source)
out_*.sql
log_*.txt

# Ad-hoc diagnostic / probe scripts (local debugging, not source)
# Review finding M4, May 2026: keeps one-off DB probes out of the repo.
# Root-level config files (eslint.config.mjs, postcss.config.mjs) are
# unaffected -- this pattern only matches scripts/.
scripts/*.mjs

# LibreOffice / Office lock files
.~lock.*#

# Validation study working artifacts (worksheet, samples, per-row agent output)
# The methodology page and methods doc describe the study; the working
# spreadsheets, JSON samples, and briefing notes are local-only and will
# be replaced by the published kappa result once raters return scores.
whel-validation-benchmark.xlsx
whel-validation-briefing-for-mom.md
scripts/validation-sample.json
scripts/validation-agent-output/
scripts/build-validation-worksheet.py
scripts/merge-pilot-into-worksheet.py
scripts/audit-output/
# Classifier API response cache (PubMed E-utilities + CT.gov v2 designs).
# Repopulated on demand by scripts/classify-sources-study-type.py; safe to
# delete locally to force refetch.
scripts/.cache/

# Guideline curation worklist CSV. Emitted by scripts/curate-guidelines.py
# --worklist as a local-only working file; the curator fills the three
# guideline_* columns by hand and feeds the result back via --apply, which
# emits a numbered SQL migration that *is* committed. The intermediate CSV
# is regenerable on demand.
scripts/guideline-curation-worklist.csv

# Python bytecode (audit scripts in scripts/ generate these on import)
__pycache__/
*.pyc

# Private working drafts (review notes, roadmap copy drafts)
WHEL-Independent-Review-*.docx
WHEL-Roadmap-page-draft.md
guideline-pdfs/

# Substrate pipeline local working store (SQLite scratch; not the production DB)
scripts/substrate/.work/
apply-substrate/
